{
  "name": "EVER Devcontainer",
  "image": "obinnamdi/ever:v1.1_full_build_vscode",
  "forwardPorts": [6006],
  "portsAttributes": {
    "6006": { "label": "ServerRenderer", "onAutoForward": "notify" }
  },
  "runArgs": [
    "--gpus",
    "all",
    "-e",
    "NVIDIA_DRIVER_CAPABILITIES=all",
    "-v",
    "/tmp/NVIDIA:/tmp/NVIDIA",
    // Properly Bind Output and Scene Directories
    "-v",
    "/home/nnamdi-obi/Desktop/projects/brdf_gaussians/outputs/flowers_output:/data/trained_model",
    "-v",
    "/home/nnamdi-obi/Desktop/projects/brdf_gaussians/datasets/flowers:/data/scene",
    // Properly bind X11 for display (https://www.pugetsystems.com/labs/hpc/NVIDIA-Docker2-with-OpenGL-and-X-Display-Output-1527/)
    "-v",
    "/tmp/.X11-unix:/tmp/.X11-unix",
    "-e",
    "XAUTHORITY",
    // Changed for MAC Display forwarding:
    "-e",
    "DISPLAY",
    "--privileged",
    // https://blog.yadutaf.fr/2017/09/10/running-a-graphical-app-in-a-docker-container-on-a-remote-server/
    "-v",
    "/home/nnamdi-obi/.Xauthority:/home/vscode/.Xauthority",

    // NEEDED for GUI Apps to work.
    "--network=host"
  ],


  "otherPortsAttributes": { "onAutoForward": "ignore" },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "shader-slang.slang-language-extension",
        "ms-vscode.cpptools",
        "eamodio.gitlens",
        "ms-python.black-formatter"
      ],
      "settings": {
        "remote.localPortHost": "127.0.0.1",
        "python.defaultInterpreterPath": "/opt/conda/envs/ever",
        "python.terminal.activateEnvironment": true,
        "git.path": "/usr/bin/git"
      }
    }
  }
  // Proper editing
  // "remoteUser": "vscode",
  // "containerUser": "vscode",
  
  // Get GUI Apps working if running with a container without these installed already
  // "postCreateCommand": [
  // "bash",
  // "-c",
  // "source activate ever && pip install matplotlib && apt update && apt install -y mesa-utils"
  // ]


}
